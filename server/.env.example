# ==========================================
# APP
# ==========================================
NODE_ENV=development
PORT=5000
APP_NAME=MERN Auth Module
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# ==========================================
# DATABASE
# ==========================================
MONGO_URI=mongodb://127.0.0.1:27017/mern-auth

# ==========================================
# REDIS (rate limiting, OTP storage, token blacklist)
# ==========================================
REDIS_URL=redis://127.0.0.1:6379

# ==========================================
# JWT
# ==========================================
JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN_REMEMBER=90d

# ==========================================
# COOKIES
# ==========================================
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ==========================================
# EMAIL VERIFICATION STRATEGY
# "code" | "link"
# ==========================================
EMAIL_VERIFICATION_METHOD=code
EMAIL_VERIFICATION_EXPIRES_MIN=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SEC=60

# ==========================================
# PASSWORD RESET
# ==========================================
PASSWORD_RESET_EXPIRES_MIN=30

# ==========================================
# ACCOUNT LOCKOUT
# ==========================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MIN=15

# ==========================================
# SOFT DELETE
# ==========================================
ACCOUNT_DELETION_GRACE_DAYS=30

# ==========================================
# SMTP
# ==========================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM_NAME=MERN Auth Module
EMAIL_FROM_ADDRESS=no-reply@example.com

# ==========================================
# CLOUDINARY
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=http://localhost:5173
